{
  "name": "merscribe",
  "version": "0.1.7",
  "private": false,
  "description": "MerScribe — a desktop whiteboard for Mermaid diagrams whose source of truth is a clean Markdown file, editable on the canvas or in the .md by an AI agent, kept in lossless two-way sync.",
  "keywords": [
    "mermaid",
    "diagram",
    "whiteboard",
    "markdown",
    "desktop",
    "electron",
    "ai-agent",
    "react-flow"
  ],
  "license": "MIT",
  "author": "GreatWhiteJ",
  "main": "electron/main.cjs",
  "homepage": "https://github.com/GreatWhiteJ/merscribe",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/GreatWhiteJ/merscribe.git"
  },
  "bugs": {
    "url": "https://github.com/GreatWhiteJ/merscribe/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "electron": "electron electron/main.cjs",
    "desktop": "next build && electron electron/main.cjs",
    "dist": "next build && node scripts/pack.mjs",
    "lint": "eslint"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@xyflow/react": "^12.10.1",
    "mermaid": "^11.12.3",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron/packager": "^20.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/dagre": "^0.7.53",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "electron": "^30.5.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
